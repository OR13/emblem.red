# Copy to .env.local (gitignored) and fill in. Restart `npm run dev` after edits.

# --- Cloudflare: enables Mark / Unmark to write real SVCB records ---
# Scoped API token with Zone.DNS:Edit on the emblem.red zone only.
CLOUDFLARE_API_TOKEN=
# Zone ID for emblem.red (Cloudflare dashboard > emblem.red > Overview,
# or: curl -s -H "Authorization: Bearer $TOKEN" \
#     "https://api.cloudflare.com/client/v4/zones?name=emblem.red" | jq '.result[0].id')
CLOUDFLARE_ZONE_ID=

# --- Issuer key (optional) ---
# Private P-256 JWK (JSON on one line). If unset, a committed INSECURE demo
# key is used. Generate one with:
#   node -e 'crypto.subtle.generateKey({name:"ECDSA",namedCurve:"P-256"},true,["sign","verify"]).then(async k=>console.log(JSON.stringify(await crypto.subtle.exportKey("jwk",k.privateKey))))'
EMBLEM_ISSUER_JWK=
EMBLEM_ISSUER_KID=emblem-demo-1
